---
import RotatingSketch from "../components/RotatingSketch.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout title="samuel debartolo">
  <section class="studio-intro" aria-labelledby="studio-title">
    <div class="studio-heading">
      <p class="eyebrow">architecture studio</p>
      <h1 id="studio-title" class="display-title">samuel debartolo</h1>
    </div>

    <div class="studio-record">
      <dl class="studio-facts" aria-label="studio details">
        <div>
          <dt>location</dt>
          <dd>tucson, arizona</dd>
        </div>
        <div>
          <dt>telephone</dt>
          <dd>
            <a href="tel:+16023270390">602.327.0390</a>
          </dd>
        </div>
        <div>
          <dt>email</dt>
          <dd>
            <a href="mailto:studio@samueldebartolo.com">
              studio@samueldebartolo.com
            </a>
          </dd>
        </div>
      </dl>

      <p class="studio-statement">
        a small architecture practice working through atmosphere, restraint,
        material character, and careful reuse.
      </p>
    </div>

    <aside class="sketch-panel" aria-label="rotating study sketch">
      <RotatingSketch />
    </aside>
  </section>
</SiteLayout>

<style>
  .studio-intro {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: clamp(18px, 2.7vw, 32px);
    row-gap: 40px;
    align-items: start;
  }

  .studio-heading {
    grid-column: 1 / span 4;
    display: grid;
    gap: clamp(28px, 4vw, 48px);
  }

  .display-title {
    max-width: 8.2em;
    margin: 0;
    font-family: Helvetica, Arial, sans-serif;
    font-size: clamp(46px, 5.1vw, 72px);
    font-weight: 400;
    letter-spacing: 0;
    line-height: 0.94;
  }

  .studio-record {
    grid-column: 5 / span 4;
    display: grid;
    gap: clamp(28px, 4vw, 52px);
  }

  .studio-facts {
    margin: 0;
    border-top: 1px solid var(--color-border);
  }

  .studio-facts div {
    display: grid;
    grid-template-columns: 86px minmax(0, 1fr);
    gap: 16px;
    align-items: center;
    border-bottom: 1px solid var(--color-border);
    padding: 13px 0;
  }

  .studio-facts dt {
    color: var(--color-text-subtle);
    font-size: 9px;
    letter-spacing: 0.12em;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .studio-facts dd {
    min-width: 0;
    margin: 0;
    color: var(--color-text);
    font-size: 12px;
    line-height: 1.35;
    overflow-wrap: anywhere;
  }

  .studio-facts a {
    border-bottom: 1px solid transparent;
    overflow-wrap: anywhere;
  }

  .studio-facts a:hover {
    border-bottom-color: currentColor;
  }

  .studio-statement {
    max-width: 28ch;
    margin: 0;
    color: var(--color-text-muted);
    font-size: clamp(21px, 2vw, 28px);
    font-weight: 400;
    line-height: 1.18;
  }

  .sketch-panel {
    grid-column: 10 / span 3;
    width: 100%;
    background: var(--color-panel);
    color: #e7e4dc;
    padding: clamp(16px, 2.1vw, 24px);
  }

  @media (max-width: 980px) {
    .studio-intro {
      grid-template-columns: repeat(8, minmax(0, 1fr));
    }

    .studio-heading {
      grid-column: 1 / span 3;
    }

    .studio-record {
      grid-column: 4 / span 4;
    }

    .sketch-panel {
      grid-column: 4 / span 5;
    }
  }

  @media (max-width: 760px) {
    .studio-intro {
      grid-template-columns: 1fr;
      row-gap: 32px;
    }

    .studio-heading,
    .studio-record,
    .sketch-panel {
      grid-column: auto;
    }

    .display-title {
      font-size: clamp(42px, 15vw, 66px);
    }

    .studio-statement {
      font-size: clamp(20px, 7vw, 27px);
    }

    .sketch-panel {
      width: min(100%, 430px);
    }
  }

  @media (max-width: 440px) {
    .studio-facts div {
      grid-template-columns: 1fr;
      gap: 5px;
    }
  }
</style>
