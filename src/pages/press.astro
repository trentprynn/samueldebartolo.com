---
import { pressLinks } from "../data/press";
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
  title="press | samuel debartolo"
  description="Press, publications, and selected references for Samuel DeBartolo's architecture work."
>
  <section class="press-page" aria-labelledby="press-title">
    <div class="section-heading">
      <p class="eyebrow">press / publications</p>
      <h1 id="press-title">selected references</h1>
    </div>

    <div class="press-list">
      {
        pressLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noreferrer"
            class="press-link"
          >
            <span>{link.title}</span>
            <small>{link.meta}</small>
          </a>
        ))
      }
    </div>
  </section>
</SiteLayout>

<style>
  .press-page {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: clamp(18px, 2.7vw, 32px);
    row-gap: 42px;
    align-items: start;
  }

  .section-heading {
    grid-column: 1 / span 4;
    display: grid;
    gap: clamp(24px, 3.8vw, 44px);
  }

  .section-heading h1 {
    max-width: 11em;
    margin: 0;
    color: var(--color-text);
    font-family: Helvetica, Arial, sans-serif;
    font-size: clamp(36px, 4.4vw, 58px);
    font-weight: 400;
    letter-spacing: 0;
    line-height: 0.98;
  }

  .press-list {
    grid-column: 5 / span 8;
    border-top: 1px solid var(--color-border);
    counter-reset: press-link;
  }

  .press-link {
    display: grid;
    grid-template-columns: 38px minmax(0, 1fr) minmax(170px, 0.42fr);
    gap: 18px;
    align-items: start;
    border-bottom: 1px solid var(--color-border);
    padding: 18px 0;
    counter-increment: press-link;
    transition:
      border-color 160ms ease,
      color 160ms ease;
  }

  .press-link::before {
    color: var(--color-text-subtle);
    font-size: 10px;
    letter-spacing: 0.1em;
    line-height: 1.16;
    transform: translateY(0.24em);
    content: counter(press-link, decimal-leading-zero);
    transition: color 160ms ease;
  }

  .press-link span {
    color: var(--color-text);
    font-size: clamp(17px, 1.6vw, 22px);
    line-height: 1.16;
    overflow-wrap: anywhere;
    transition: color 160ms ease;
  }

  .press-link small {
    color: var(--color-text-muted);
    font-size: 10px;
    letter-spacing: 0.08em;
    line-height: 1.35;
    padding-top: 0.32em;
    text-transform: uppercase;
    transition: color 160ms ease;
  }

  .press-link:hover,
  .press-link:focus-visible {
    border-bottom-color: var(--color-border-strong);
  }

  .press-link:hover::before,
  .press-link:focus-visible::before,
  .press-link:hover small,
  .press-link:focus-visible small {
    color: var(--color-text);
  }

  .press-link:hover span,
  .press-link:focus-visible span {
    color: var(--color-accent);
  }

  @media (max-width: 980px) {
    .press-page {
      grid-template-columns: repeat(8, minmax(0, 1fr));
    }

    .section-heading {
      grid-column: 1 / span 3;
    }

    .press-list {
      grid-column: 4 / span 5;
    }
  }

  @media (max-width: 760px) {
    .press-page {
      grid-template-columns: 1fr;
      row-gap: 32px;
    }

    .section-heading,
    .press-list {
      grid-column: auto;
    }

    .press-link {
      grid-template-columns: 30px 1fr;
      gap: 7px 14px;
    }

    .press-link small {
      grid-column: 2;
    }
  }

  @media (max-width: 440px) {
    .section-heading h1 {
      font-size: clamp(32px, 12vw, 46px);
    }
  }
</style>
